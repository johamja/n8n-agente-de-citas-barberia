    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\n\n// Helper: toma el primer valor \"util\" descartando undefined/null/vacios y la cadena literal \"undefined\"/\"null\"\nconst pick = (...vals) => {\n  for (const v of vals) {\n    if (v === undefined || v === null) continue;\n    const s = String(v).trim();\n    if (!s) continue;\n    const low = s.toLowerCase();\n    if (low === 'undefined' || low === 'null') continue;\n    return s;\n  }\n  return '';\n};\n\n// Parsear query tipo: \"Nombre: Joham, Servicio: Corte + Barba, Fecha: 2026-04-15, Hora: 09:00\"\nconst query = typeof item.query === 'string' ? item.query : '';\nconst parsed = {};\nfor (const part of query.split(',').map(p => p.trim())) {\n  const colonIdx = part.indexOf(':');\n  if (colonIdx === -1) continue;\n  const rawKey = part.substring(0, colonIdx).trim().toLowerCase()\n    .normalize('NFD').replace(/[\\u0300-\\u036f]/g, ''); // quitar tildes\n  const value = part.substring(colonIdx + 1).trim();\n  parsed[rawKey] = value;\n}\n\n// Para los campos que el LLM suele emitir como query: parsed gana sobre item (evita que \"undefined\" contamine).\nconst nombre   = pick(parsed.nombre,   item.nombre);\nconst servicio = pick(parsed.servicio, item.servicio);\nconst fecha    = pick(parsed.fecha,    item.fecha);\nconst hora     = pick(parsed.hora,     item.hora);\nconst numero   = pick(parsed.numero,   item.numero);\n\n// accion viene fija desde el flujo 01 via expresion; item gana sobre parsed.\nlet accion = pick(item.accion, parsed.accion).toLowerCase();\nif (!accion) {\n  if (servicio && hora)         accion = 'agendar';\n  else if (nombre && !servicio) accion = 'cancelar';\n  else                          accion = 'consultar';\n}\n\nreturn [{\n  json: { accion, nombre, servicio, fecha, hora, numero }\n}];"
      },
