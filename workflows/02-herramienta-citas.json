    {
      "parameters": {
        "jsCode": "const duraciones = {\n  'corte': 30, 'corte de cabello': 30,\n  'corte + barba': 45, 'corte barba': 45, 'corte+barba': 45,\n  'corte ninos': 25, 'corte niños': 25, 'ninos': 25, 'niños': 25,\n  'afeitado': 20, 'afeitado tradicional': 20,\n  'diseno barba': 20, 'diseño barba': 20, 'diseño de barba': 20,\n  'tratamiento': 45, 'tratamiento capilar': 45,\n  'masaje': 35, 'masaje cuero cabelludo': 35\n};\n\nconst item = $input.first().json;\n\n// Validar datos minimos: si falta fecha, hora, nombre o servicio, retornar resultado claro sin tocar el calendario\nconst falta = [];\nif (!item.fecha)    falta.push('fecha');\nif (!item.hora)     falta.push('hora');\nif (!item.nombre)   falta.push('nombre');\nif (!item.servicio) falta.push('servicio');\nif (falta.length) {\n  return [{ json: { ...item, _error: true, resultado: `Faltan datos para agendar: ${falta.join(', ')}.` } }];\n}\n\nconst servicio = item.servicio.toLowerCase();\nconst duracion = duraciones[servicio] || 30;\n\nconst fechaHora = `${item.fecha}T${item.hora}:00`;\nconst inicio = new Date(fechaHora);\nif (isNaN(inicio.getTime())) {\n  return [{ json: { ...item, _error: true, resultado: `Fecha u hora invalidas: ${item.fecha} ${item.hora}.` } }];\n}\nconst fin = new Date(inicio.getTime() + duracion * 60000);\n\nconst pad = n => String(n).padStart(2, '0');\nconst finStr = `${fin.getFullYear()}-${pad(fin.getMonth()+1)}-${pad(fin.getDate())}T${pad(fin.getHours())}:${pad(fin.getMinutes())}:00`;\n\nreturn [{\n  json: {\n    ...item,\n    duracion,\n    fechaHoraInicio: fechaHora,\n    fechaHoraFin: finStr,\n    titulo: `Cita: ${item.servicio} - ${item.nombre}`,\n    descripcion: `Cliente: ${item.nombre}\\nTel: ${item.numero || 'N/A'}\\nServicio: ${item.servicio}`\n  }\n}];"
      },
