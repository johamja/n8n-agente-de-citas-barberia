# ========================================
# .env.example - Variables de Entorno
# ========================================
# Copiar a .env y llenar con valores reales
# NUNCA commitear .env al repositorio

# n8n Configuration
N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_ENCRYPTION_KEY=change-me-random-string
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=admin

# Webhook
WEBHOOK_URL=http://localhost:5678

# Timezone
TZ=America/Bogota
GENERIC_TIMEZONE=America/Bogota

# PostgreSQL
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=barberia_db
DB_POSTGRESDB_USER=barberia_user
DB_POSTGRESDB_PASSWORD=secure_password_here

# Google Calendar
GOOGLE_CALENDAR_API_KEY=
GOOGLE_CALENDAR_ID=

# WhatsApp Business API
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=secure_token

# Telegram Bot
TELEGRAM_BOT_TOKEN=

# Email (Opcional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@barberia.com

# Logging
LOG_LEVEL=info
DEBUG=false
