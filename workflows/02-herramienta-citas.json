    {
      "parameters": {
        "jsCode": "const eventos = $input.all().map(e => e.json);\nconst fecha = $('Parsear Datos').item.json.fecha;\n\nconst slots = [];\nconst turnos = [\n  { inicio: 8, fin: 12 },\n  { inicio: 14, fin: 18 }\n];\n\nfor (const turno of turnos) {\n  for (let h = turno.inicio; h < turno.fin; h++) {\n    slots.push(`${String(h).padStart(2,'0')}:00`);\n    slots.push(`${String(h).padStart(2,'0')}:30`);\n  }\n}\n\nconst ocupados = eventos.map(e => {\n  const dt = new Date(e.start?.dateTime || e.start?.date);\n  return `${String(dt.getHours()).padStart(2,'0')}:${String(dt.getMinutes()).padStart(2,'0')}`;\n});\n\nconst libres = slots.filter(s => !ocupados.includes(s));\n\nconst respuesta = libres.length > 0\n  ? `Horarios disponibles el ${fecha}: ` + libres.join(', ')\n  : `No hay horarios disponibles el ${fecha}. Elige otra fecha.`;\n\nreturn [{ json: { resultado: respuesta } }];"
      },
